+// ── Shared print template ─────────────────────────────────────────────────────
+function buildPrintHtml(opts: {
+  id: string;
+  date: string;
+  variety: string;
+  batch: string;
+  quantity: number;
+  location: string;
+  notes?: string | null;
+  customerName?: string | null;
+  destination?: string | null;
+}) {
+  return `<!DOCTYPE html>
+<html>
+<head>
+  <meta charset="utf-8">
+  <title>Dispatch Slip</title>
+  <style>
+    @media print {
+      @page { size: 80mm auto; margin: 0; }
+      body { margin: 0; padding: 0; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
+    }
+    * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
+    body { font-family: 'Courier New', monospace; font-size: 12px; line-height: 1.4; padding: 10mm; max-width: 80mm; margin: 0 auto; color: #000 !important; }
+    .header { text-align: center; border-bottom: 2px dashed #000; padding-bottom: 8px; margin-bottom: 12px; }
+    .header h1 { margin: 0; font-size: 18px; font-weight: bold; }
+    .header h2 { margin: 4px 0 0 0; font-size: 14px; font-weight: normal; }
+    .section { margin-bottom: 12px; }
+    .section-title { font-weight: bold; font-size: 14px; margin-bottom: 4px; text-transform: uppercase; }
+    .info-row { display: flex; justify-content: space-between; margin-bottom: 3px; }
+    .label { font-weight: bold; }
+    .value { text-align: right; font-weight: bold; }
+    .footer { border-top: 2px dashed #000; padding-top: 8px; margin-top: 12px; text-align: center; font-size: 10px; }
+    .notes { border: 1px solid #000; padding: 6px; margin-top: 8px; min-height: 40px; font-weight: bold; }
+    table { width: 100%; border-collapse: collapse; margin: 8px 0; }
+    th, td { text-align: left; padding: 8px 4px; border-bottom: 2px solid #000; font-size: 16px; color: #000; font-weight: bold; }
+    th { font-weight: 900; background: #f0f0f0 !important; font-size: 18px; }
+  </style>
+</head>
+<body>
+  <div class="header">
+    <h1>DISPATCH SLIP</h1>
+    <h2>Seedlings Nursery</h2>
+  </div>
+  <div class="section">
+    <div class="section-title">Order Details</div>
+    <div class="info-row"><span class="label">Dispatch ID:</span><span class="value">${opts.id.slice(0, 8)}</span></div>
+    <div class="info-row"><span class="label">Date:</span><span class="value">${new Date(opts.date).toLocaleDateString()}</span></div>
+    <div class="info-row"><span class="label">Time:</span><span class="value">${new Date().toLocaleTimeString()}</span></div>
+    ${opts.customerName ? `<div class="info-row"><span class="label">Customer:</span><span class="value">${opts.customerName}</span></div>` : ""}
+    ${opts.destination ? `<div class="info-row"><span class="label">Destination:</span><span class="value">${opts.destination}</span></div>` : ""}
+  </div>
+  <div class="section">
+    <div class="section-title">Product Information</div>
+    <table>
+      <tr><th>Variety</th><th>Batch</th><th>Qty</th><th>Location</th></tr>
+      <tr>
+        <td>${opts.variety}</td>
+        <td>${opts.batch}</td>
+        <td>${opts.quantity.toLocaleString()}</td>
+        <td>${opts.location}</td>
+      </tr>
+    </table>
+  </div>
+  ${opts.notes ? `<div class="section"><div class="notes">${opts.notes}</div></div>` : '<div class="section"><div class="notes"></div></div>'}
+  <div class="footer">
+    <p>Packed by: _________________</p>
+    <p>Checked by: _________________</p>
+    <p style="margin-top: 8px;">Thank you for your business!</p>
+  </div>
+</body>
+</html>`;
